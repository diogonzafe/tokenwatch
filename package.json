{
  "name": "@diogonzafe/tokenwatch",
  "version": "0.1.2",
  "description": "Transparent wrapper to track LLM API costs in real-time by session, user and model",
  "author": "diogonzafe",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "tokenwatch": "./dist/cli.js"
  },
  "files": [
    "dist",
    "prices.json"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^20.17.0",
    "playwright": "^1.59.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": ">=0.26.0",
    "@google/generative-ai": ">=0.21.0",
    "better-sqlite3": ">=11.0.0",
    "openai": ">=4.68.0"
  },
  "peerDependenciesMeta": {
    "openai": {
      "optional": true
    },
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "@google/generative-ai": {
      "optional": true
    },
    "better-sqlite3": {
      "optional": true
    }
  },
  "keywords": [
    "llm",
    "cost",
    "tracker",
    "openai",
    "anthropic",
    "gemini",
    "deepseek",
    "tokens",
    "usage"
  ],
  "engines": {
    "node": ">=20.0.0"
  }
}
